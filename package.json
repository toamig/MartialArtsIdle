{
  "name": "martialartsidle",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:native": "vite --mode native",
    "dev:designer": "vite --mode designer",
    "build": "vite build --mode browser",
    "build:browser": "vite build --mode browser",
    "build:native": "vite build --mode native",
    "build:android": "npm run build:native && cap sync android && cap open android",
    "build:ios": "npm run build:native && cap sync ios && cap open ios",
    "build:steam": "vite build --mode steam",
    "build:demo": "vite build --mode demo",
    "build:desktop": "vite build --mode steam && electron-builder",
    "build:designer": "vite build --mode designer",
    "preview:demo": "npm run build:demo && vite preview --host",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.martialartsidle.app",
    "productName": "The Long Road to Heaven",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/main.cjs",
      "electron/preload.cjs"
    ],
    "afterPack": "electron/afterPack.cjs",
    "win": {
      "target": "portable",
      "icon": "public/app-icon.ico"
    },
    "asar": false
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "howler": "^2.2.4",
    "i18next": "^26.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.3",
    "vite-plugin-pwa": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "rcedit": "^5.0.2",
    "vite": "^8.0.4"
  }
}
